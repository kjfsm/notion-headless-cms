---
import { env } from "cloudflare:workers";
import { createCMS } from "../../lib/cms";

const cms = createCMS(env as unknown as Parameters<typeof createCMS>[0]);
const { slug } = Astro.params;
const entry = await cms.cache.get(slug!);

if (!entry) return Astro.redirect("/404");

const { html, item } = entry;
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <title>{item.slug}</title>
  </head>
  <body>
    <article>
      <h1>{item.slug}</h1>
      {item.publishedAt && <time>{item.publishedAt}</time>}
      {item.author && <p>Author: {item.author}</p>}
      <div set:html={html} />
    </article>
  </body>
</html>
