---
import { env } from "cloudflare:workers";
import { makeCms } from "../../lib/cms";
import { getPost } from "../../lib/data";

const cms = makeCms(env as unknown as Parameters<typeof makeCms>[0]);
const { slug } = Astro.params;
if (!slug) return Astro.redirect("/404");
const result = await getPost(cms, slug);

if (!result) return Astro.redirect("/404");

const { post, html } = result;
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <title>{post.slug}</title>
  </head>
  <body>
    <article>
      <h1>{post.slug}</h1>
      {post.publishedAt && <time>{post.publishedAt}</time>}
      <div set:html={html} />
    </article>
  </body>
</html>
