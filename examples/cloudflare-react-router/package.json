{
  "name": "example-cloudflare-react-router",
  "private": true,
  "version": "0.0.30",
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "cf-typegen": "wrangler types && react-router typegen",
    "check": "tsc && react-router build && wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "dev": "react-router dev",
    "env": "dotenv -e .dev.vars",
    "generate": "nhc generate",
    "preview": "pnpm run build && vite preview",
    "wrangler:dev": "rm -f .wrangler/deploy/config.json && pnpm run build && wrangler dev",
    "test": "vitest run",
    "test:screenshots": "PLAYWRIGHT_HTML_OPEN=never playwright test",
    "typecheck": "pnpm run cf-typegen && tsc -b",
    "test:e2e": "PLAYWRIGHT_HTML_OPEN=never playwright test e2e/navigation.spec.ts"
  },
  "dependencies": {
    "@notion-headless-cms/cache": "workspace:*",
    "@notion-headless-cms/core": "workspace:*",
    "@notion-headless-cms/notion-embed": "workspace:*",
    "@notion-headless-cms/notion-orm": "workspace:*",
    "@notion-headless-cms/react-renderer": "workspace:*",
    "@notion-headless-cms/renderer": "workspace:*",
    "@notionhq/client": "catalog:",
    "@react-router/cloudflare": "^7.14.2",
    "dotenv": "^17.4.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^7.14.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.33.2",
    "@notion-headless-cms/cli": "workspace:*",
    "@playwright/test": "catalog:",
    "@react-router/dev": "^7.14.2",
    "@tailwindcss/vite": "^4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv-cli": "^11.0.0",
    "tailwindcss": "^4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^3.2.0",
    "wrangler": "^4.85.0"
  }
}
