{
	"name": "example-cloudflare-sveltekit",
	"private": true,
	"version": "0.0.4",
	"type": "module",
	"scripts": {
		"dev": "nhc generate && vite dev",
		"build": "nhc generate && vite build",
		"preview": "pnpm run build && wrangler dev",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"deploy": "pnpm run build && wrangler deploy",
		"cf-typegen": "wrangler types"
	},
	"dependencies": {
		"@notion-headless-cms/adapter-cloudflare": "workspace:*",
		"@notion-headless-cms/core": "workspace:*",
		"@notion-headless-cms/notion-orm": "workspace:*",
		"zod": "^4.1.12"
	},
	"devDependencies": {
		"@notion-headless-cms/cli": "workspace:*",
		"@sveltejs/adapter-cloudflare": "^7.0.0",
		"@sveltejs/kit": "^2.0.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^25.6.0",
		"svelte": "^5.0.0",
		"typescript": "^6.0.3",
		"vite": "^6.0.0",
		"wrangler": "^4.84.1"
	}
}
