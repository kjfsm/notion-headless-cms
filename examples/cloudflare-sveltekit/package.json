{
	"name": "example-cloudflare-sveltekit",
	"private": true,
	"version": "0.0.2",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "pnpm run build && wrangler dev",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"deploy": "pnpm run build && wrangler deploy",
		"cf-typegen": "wrangler types"
	},
	"dependencies": {
		"@notion-headless-cms/adapter-cloudflare": "workspace:*",
		"@notion-headless-cms/source-notion": "workspace:*",
		"zod": "^4.1.12"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"@sveltejs/adapter-cloudflare": "^7.0.0",
		"@sveltejs/kit": "^2.0.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"svelte": "^5.0.0",
		"typescript": "^5.9.0",
		"vite": "^6.0.0",
		"wrangler": "^4.83.0"
	}
}
