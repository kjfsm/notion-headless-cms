{
  "name": "example-node-hono",
  "private": true,
  "version": "0.0.24",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "build": "tsc",
    "generate": "nhc generate",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:screenshots": "PLAYWRIGHT_HTML_OPEN=never playwright test",
    "test:e2e": "PLAYWRIGHT_HTML_OPEN=never playwright test e2e/navigation.spec.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.0",
    "@notion-headless-cms/cache": "workspace:*",
    "@notion-headless-cms/core": "workspace:*",
    "@notion-headless-cms/notion-orm": "workspace:*",
    "@notion-headless-cms/renderer": "workspace:*",
    "hono": "^4.12.15",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@notion-headless-cms/cli": "workspace:*",
    "@playwright/test": "catalog:",
    "@types/node": "^25.6.0",
    "dotenv": "^17.4.2",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.0"
  }
}
