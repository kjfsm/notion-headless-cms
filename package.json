{
	"name": "notion-headless-cms",
	"private": true,
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kjfsm/notion-headless-cms.git"
	},
	"type": "module",
	"packageManager": "pnpm@10.33.0",
	"scripts": {
		"build": "turbo run build --filter=\"./packages/*\"",
		"typecheck": "turbo run typecheck --filter=\"./packages/*\"",
		"test": "turbo run test --filter=\"./packages/*\"",
		"format": "biome check --write",
		"lint": "biome ci",
		"changeset": "changeset",
		"version": "changeset version",
		"cf-typegen": "pnpm --filter example-cloudflare-* cf-typegen",
		"release": "changeset publish"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@changesets/cli": "^2.31.0",
		"tsdown": "^0.21.10",
		"turbo": "^2.9.6",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	}
}
