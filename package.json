{
	"name": "notion-headless-cms",
	"private": true,
	"repository": {
		"type": "git",
		"url": "https://github.com/kjfsm/notion-headless-cms.git"
	},
	"type": "module",
	"scripts": {
		"build": "pnpm -r run build",
		"typecheck": "pnpm -r run typecheck",
		"test": "vitest run",
		"format": "biome check --write",
		"lint": "biome ci",
		"changeset": "changeset",
		"version": "changeset version",
		"cf-typegen": "pnpm --filter example-cloudflare-* cf-typegen",
		"release": "changeset publish"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@changesets/cli": "^2.31.0",
		"tsup": "^8.5.1",
		"typescript": "^5.0.0",
		"vitest": "^4.1.5"
	}
}
