{
	"name": "@notion-headless-cms/adapter-cloudflare",
	"version": "0.2.0",
	"description": "Cloudflare Workers adapter for notion-headless-cms — injects R2 storage and environment bindings",
	"keywords": [
		"notion",
		"headless-cms",
		"cloudflare",
		"cloudflare-workers",
		"workers",
		"adapter",
		"typescript"
	],
	"license": "MIT",
	"homepage": "https://github.com/kjfsm/notion-headless-cms#readme",
	"bugs": {
		"url": "https://github.com/kjfsm/notion-headless-cms/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kjfsm/notion-headless-cms.git",
		"directory": "packages/adapter-cloudflare"
	},
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		}
	},
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"build": "tsdown src/index.ts --format esm --dts --sourcemap --out-dir dist",
		"typecheck": "tsc --noEmit"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true,
		"exports": {
			".": {
				"types": "./dist/index.d.mts",
				"import": "./dist/index.mjs"
			}
		}
	},
	"dependencies": {
		"@notion-headless-cms/cache-kv": "workspace:*",
		"@notion-headless-cms/cache-r2": "workspace:*",
		"@notion-headless-cms/core": "workspace:*",
		"@notion-headless-cms/renderer": "workspace:*",
		"@notion-headless-cms/notion-orm": "workspace:*",
		"@notionhq/client": "catalog:",
		"rehype-stringify": "catalog:",
		"remark-gfm": "catalog:",
		"remark-parse": "catalog:",
		"remark-rehype": "catalog:",
		"unified": "catalog:",
		"zod": "catalog:"
	},
	"peerDependencies": {
		"@cloudflare/workers-types": ">=4.0.0"
	},
	"peerDependenciesMeta": {
		"@cloudflare/workers-types": {
			"optional": true
		}
	},
	"devDependencies": {
		"@cloudflare/workers-types": "catalog:"
	}
}
