{
	"name": "@notion-headless-cms/adapter-next",
	"version": "0.2.2",
	"description": "Next.js App Router adapter for notion-headless-cms — image route handler and revalidate webhook",
	"keywords": [
		"notion",
		"headless-cms",
		"nextjs",
		"next",
		"adapter",
		"typescript"
	],
	"license": "MIT",
	"homepage": "https://github.com/kjfsm/notion-headless-cms#readme",
	"bugs": {
		"url": "https://github.com/kjfsm/notion-headless-cms/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/kjfsm/notion-headless-cms.git",
		"directory": "packages/adapter-next"
	},
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"build": "tsup src/index.ts --format esm --dts --sourcemap --out-dir dist",
		"typecheck": "tsc --noEmit",
		"test": "vitest run"
	},
	"publishConfig": {
		"access": "public",
		"exports": {
			".": {
				"import": "./dist/index.js",
				"types": "./dist/index.d.ts"
			}
		}
	},
	"peerDependencies": {
		"next": ">=14.0.0"
	},
	"dependencies": {
		"@notion-headless-cms/core": "workspace:*"
	}
}
