{
	"name": "@notion-headless-cms/adapter-next",
	"version": "0.2.13",
	"description": "Next.js App Router adapter for notion-headless-cms — image route handler and revalidate webhook",
	"keywords": [
		"notion",
		"headless-cms",
		"nextjs",
		"next",
		"adapter",
		"typescript"
	],
	"license": "MIT",
	"homepage": "https://github.com/kjfsm/notion-headless-cms#readme",
	"bugs": {
		"url": "https://github.com/kjfsm/notion-headless-cms/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kjfsm/notion-headless-cms.git",
		"directory": "packages/adapter-next"
	},
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		}
	},
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"build": "tsdown src/index.ts --format esm --dts --sourcemap --out-dir dist",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage --coverage.reporter=lcov --coverage.reporter=text",
		"publint": "publint --strict",
		"attw": "attw --pack . --profile esm-only"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"peerDependencies": {
		"next": ">=14.0.0"
	},
	"dependencies": {
		"@notion-headless-cms/core": "workspace:*"
	}
}
