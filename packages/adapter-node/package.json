{
	"name": "@notion-headless-cms/adapter-node",
	"version": "0.1.5",
	"description": "Node.js adapter for notion-headless-cms — createNodeCMS() factory with process.env support",
	"keywords": [
		"notion",
		"headless-cms",
		"node",
		"nodejs",
		"adapter",
		"typescript"
	],
	"license": "MIT",
	"homepage": "https://github.com/kjfsm/notion-headless-cms#readme",
	"bugs": {
		"url": "https://github.com/kjfsm/notion-headless-cms/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/kjfsm/notion-headless-cms.git",
		"directory": "packages/adapter-node"
	},
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		}
	},
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"build": "tsdown src/index.ts --format esm --dts --sourcemap --out-dir dist",
		"typecheck": "tsc --noEmit"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true,
		"exports": {
			".": {
				"types": "./dist/index.d.mts",
				"import": "./dist/index.mjs"
			}
		}
	},
	"dependencies": {
		"@notion-headless-cms/core": "workspace:*",
		"@notion-headless-cms/renderer": "workspace:*",
		"@notion-headless-cms/source-notion": "workspace:*",
		"@notionhq/client": "^5.20.0",
		"rehype-stringify": "^10.0.1",
		"remark-gfm": "^4.0.1",
		"remark-parse": "^11.0.0",
		"remark-rehype": "^11.1.2",
		"unified": "^11.0.5",
		"zod": "^4.0.0"
	},
	"devDependencies": {
		"@types/node": "^25.6.0"
	}
}
