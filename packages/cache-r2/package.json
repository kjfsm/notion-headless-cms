{
	"name": "@kjfsm/notion-headless-cms-cache-r2",
	"version": "0.1.0",
	"description": "Cloudflare R2 storage adapter (cache layer) for notion-headless-cms",
	"keywords": [
		"notion",
		"headless-cms",
		"cloudflare",
		"r2"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/kjfsm/notion-headless-cms.git",
		"directory": "packages/cache-r2"
	},
	"type": "module",
	"exports": {
		".": "./src/index.ts"
	},
	"scripts": {
		"build": "tsup src/index.ts --format esm --dts --out-dir dist",
		"typecheck": "tsc --noEmit"
	},
	"publishConfig": {
		"registry": "https://npm.pkg.github.com",
		"access": "restricted",
		"exports": {
			".": {
				"import": "./dist/index.js",
				"types": "./dist/index.d.ts"
			}
		}
	},
	"dependencies": {
		"@kjfsm/notion-headless-cms-core": "workspace:*"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20250620.0"
	}
}
