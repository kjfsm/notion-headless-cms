{
	"name": "@notion-headless-cms/cache-r2",
	"version": "0.2.0",
	"description": "Cloudflare R2 StorageAdapter implementation for notion-headless-cms cache layer",
	"keywords": [
		"notion",
		"headless-cms",
		"cloudflare",
		"cloudflare-r2",
		"r2",
		"cache",
		"workers",
		"typescript"
	],
	"license": "MIT",
	"homepage": "https://github.com/kjfsm/notion-headless-cms#readme",
	"bugs": {
		"url": "https://github.com/kjfsm/notion-headless-cms/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kjfsm/notion-headless-cms.git",
		"directory": "packages/cache-r2"
	},
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		}
	},
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"build": "tsdown src/index.ts --format esm --dts --sourcemap --out-dir dist",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"publint": "publint --strict",
		"attw": "attw --pack . --profile esm-only",
		"prepublishOnly": "pnpm run build"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"dependencies": {
		"@notion-headless-cms/cache-kv": "workspace:*",
		"@notion-headless-cms/core": "workspace:*"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "catalog:"
	}
}
