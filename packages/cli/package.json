{
	"name": "@notion-headless-cms/cli",
	"version": "0.1.1",
	"description": "CLI tool for notion-headless-cms — generates schema files from Notion databases",
	"keywords": [
		"notion",
		"headless-cms",
		"cli",
		"codegen",
		"typescript"
	],
	"license": "MIT",
	"homepage": "https://github.com/kjfsm/notion-headless-cms#readme",
	"bugs": {
		"url": "https://github.com/kjfsm/notion-headless-cms/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/kjfsm/notion-headless-cms.git",
		"directory": "packages/cli"
	},
	"type": "module",
	"bin": {
		"nhc": "./bin/nhc.js"
	},
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"build": "tsup src/index.ts src/cli.ts --format esm --dts --sourcemap --out-dir dist",
		"typecheck": "tsc --noEmit",
		"test": "vitest run"
	},
	"publishConfig": {
		"access": "public",
		"exports": {
			".": {
				"import": "./dist/index.js",
				"types": "./dist/index.d.ts"
			}
		}
	},
	"dependencies": {
		"@notionhq/client": "^5.18.0",
		"commander": "^12.0.0",
		"jiti": "^2.0.0"
	},
	"devDependencies": {
		"@types/node": "^22.0.0"
	}
}
