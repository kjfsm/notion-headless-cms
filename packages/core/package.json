{
  "name": "@kjfsm/notion-core",
  "version": "0.0.1",
  "description": "Notion API integration and content processing",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "lint": "biome lint src",
    "format": "biome format src --write",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "dependencies": {
    "@notionhq/client": "^5.18.0",
    "marked": "^15.0.0",
    "notion-to-md": "4.0.0-alpha.7"
  },
  "devDependencies": {}
}
