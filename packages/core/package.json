{
	"name": "@notion-headless-cms/core",
	"version": "0.0.3",
	"description": "Core CMS engine for notion-headless-cms — fetch, transform, cache with stale-while-revalidate strategy",
	"keywords": [
		"notion",
		"headless-cms",
		"cms",
		"cache",
		"stale-while-revalidate",
		"typescript"
	],
	"license": "MIT",
	"homepage": "https://github.com/kjfsm/notion-headless-cms#readme",
	"bugs": {
		"url": "https://github.com/kjfsm/notion-headless-cms/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/kjfsm/notion-headless-cms.git",
		"directory": "packages/core"
	},
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": "./src/index.ts"
	},
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"build": "tsup src/index.ts --format esm --dts --out-dir dist",
		"typecheck": "tsc --noEmit",
		"test": "vitest run"
	},
	"publishConfig": {
		"registry": "https://registry.npmjs.org",
		"access": "public",
		"exports": {
			".": {
				"import": "./dist/index.js",
				"types": "./dist/index.d.ts"
			}
		}
	},
	"dependencies": {
		"@notion-headless-cms/fetcher": "workspace:*",
		"@notion-headless-cms/transformer": "workspace:*",
		"@notion-headless-cms/renderer": "workspace:*",
		"@notionhq/client": "^5.18.0",
		"unified": "^11.0.5",
		"zod": "^4.1.12"
	}
}
