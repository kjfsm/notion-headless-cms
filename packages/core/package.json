{
	"name": "@kjfsm/notion-headless-cms-core",
	"version": "0.1.0",
	"description": "Core CMS engine for notion-headless-cms",
	"keywords": [
		"notion",
		"headless-cms"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/kjfsm/notion-headless-cms.git",
		"directory": "packages/core"
	},
	"type": "module",
	"exports": {
		".": "./src/index.ts"
	},
	"scripts": {
		"build": "tsup src/index.ts --format esm --dts --out-dir dist",
		"typecheck": "tsc --noEmit"
	},
	"publishConfig": {
		"registry": "https://npm.pkg.github.com",
		"access": "restricted",
		"exports": {
			".": {
				"import": "./dist/index.js",
				"types": "./dist/index.d.ts"
			}
		}
	},
	"dependencies": {
		"@kjfsm/notion-headless-cms-fetcher": "workspace:*",
		"@kjfsm/notion-headless-cms-transformer": "workspace:*",
		"@kjfsm/notion-headless-cms-renderer": "workspace:*",
		"@notionhq/client": "^5.18.0",
		"unified": "^11.0.5",
		"zod": "^4.1.12"
	}
}
