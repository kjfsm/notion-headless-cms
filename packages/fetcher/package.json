{
	"name": "@kjfsm/notion-headless-cms-fetcher",
	"version": "0.1.0",
	"description": "Notion API fetching layer for notion-headless-cms",
	"keywords": [
		"notion",
		"headless-cms"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/kjfsm/notion-headless-cms.git",
		"directory": "packages/fetcher"
	},
	"type": "module",
	"exports": {
		".": "./src/index.ts"
	},
	"scripts": {
		"build": "tsup src/index.ts --format esm --dts --out-dir dist",
		"typecheck": "tsc --noEmit"
	},
	"publishConfig": {
		"registry": "https://npm.pkg.github.com",
		"access": "restricted",
		"exports": {
			".": {
				"import": "./dist/index.js",
				"types": "./dist/index.d.ts"
			}
		}
	},
	"dependencies": {
		"@notionhq/client": "^5.18.0"
	}
}
