{
	"name": "@notion-headless-cms/notion-orm",
	"version": "0.0.6",
	"description": "Notion ORM layer for notion-headless-cms — implements DataSource<T>. Consumed via CLI-generated nhc-schema.ts.",
	"keywords": [
		"notion",
		"notion-api",
		"headless-cms",
		"cms",
		"datasource",
		"orm",
		"typescript"
	],
	"license": "MIT",
	"homepage": "https://github.com/kjfsm/notion-headless-cms#readme",
	"bugs": {
		"url": "https://github.com/kjfsm/notion-headless-cms/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kjfsm/notion-headless-cms.git",
		"directory": "packages/notion-orm"
	},
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		}
	},
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"build": "tsdown src/index.ts --format esm --dts --sourcemap --out-dir dist",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage --coverage.reporter=lcov --coverage.reporter=text",
		"publint": "publint --strict",
		"attw": "attw --pack . --profile esm-only"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"dependencies": {
		"@notion-headless-cms/core": "workspace:*",
		"notion-to-md": "^3.1.0"
	},
	"peerDependencies": {
		"@notionhq/client": "^5.20.0",
		"zod": "^4.0.0"
	},
	"devDependencies": {
		"@notionhq/client": "catalog:",
		"zod": "catalog:"
	}
}
