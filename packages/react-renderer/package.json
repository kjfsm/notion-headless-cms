{
  "name": "@notion-headless-cms/react-renderer",
  "version": "0.0.2",
  "description": "Notion ブロックを React コンポーネントとして直接描画するレンダラ。shadcn/ui + Tailwind v4 ベース。",
  "keywords": [
    "notion",
    "headless-cms",
    "react",
    "renderer",
    "shadcn",
    "tailwindcss",
    "typescript"
  ],
  "license": "MIT",
  "homepage": "https://github.com/kjfsm/notion-headless-cms#readme",
  "bugs": {
    "url": "https://github.com/kjfsm/notion-headless-cms/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kjfsm/notion-headless-cms.git",
    "directory": "packages/react-renderer"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./server": {
      "types": "./dist/server.d.mts",
      "import": "./dist/server.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsdown src/index.ts src/server.ts --format esm --dts --sourcemap --out-dir dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --coverage.reporter=lcov --coverage.reporter=text",
    "publint": "publint --strict",
    "attw": "attw --pack . --profile esm-only"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "peerDependencies": {
    "@notionhq/client": "^5.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "@notionhq/client": {
      "optional": true
    }
  },
  "dependencies": {
    "@radix-ui/react-aspect-ratio": "^1.1.2",
    "@radix-ui/react-collapsible": "^1.1.3",
    "clsx": "^2.1.1",
    "katex": "^0.16.11",
    "lucide-react": "^0.468.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@notionhq/client": "catalog:",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "happy-dom": "^20.9.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
