{
	"name": "@kjfsm/notion-headless-cms-renderer",
	"version": "0.1.0",
	"description": "Markdown → HTML renderer using remark/rehype for notion-headless-cms",
	"keywords": [
		"notion",
		"headless-cms",
		"remark",
		"rehype"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/kjfsm/notion-headless-cms.git",
		"directory": "packages/renderer"
	},
	"type": "module",
	"exports": {
		".": "./src/index.ts"
	},
	"scripts": {
		"build": "tsup src/index.ts --format esm --dts --out-dir dist",
		"typecheck": "tsc --noEmit",
		"test": "vitest run"
	},
	"publishConfig": {
		"registry": "https://npm.pkg.github.com",
		"access": "restricted",
		"exports": {
			".": {
				"import": "./dist/index.js",
				"types": "./dist/index.d.ts"
			}
		}
	},
	"dependencies": {
		"@types/hast": "^3.0.4",
		"rehype-stringify": "^10.0.1",
		"remark-gfm": "^4.0.1",
		"remark-parse": "^11.0.0",
		"remark-rehype": "^11.1.2",
		"unified": "^11.0.5",
		"unist-util-visit": "^5.0.0"
	}
}
