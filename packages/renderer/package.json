{
	"name": "@notion-headless-cms/renderer",
	"version": "0.1.1",
	"description": "Markdown to HTML renderer using remark/rehype for notion-headless-cms",
	"keywords": [
		"notion",
		"headless-cms",
		"markdown",
		"html",
		"remark",
		"rehype",
		"unified",
		"typescript"
	],
	"license": "MIT",
	"homepage": "https://github.com/kjfsm/notion-headless-cms#readme",
	"bugs": {
		"url": "https://github.com/kjfsm/notion-headless-cms/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kjfsm/notion-headless-cms.git",
		"directory": "packages/renderer"
	},
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		}
	},
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"build": "tsdown src/index.ts --format esm --dts --sourcemap --out-dir dist",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"prepublishOnly": "pnpm run build"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true,
		"exports": {
			".": {
				"types": "./dist/index.d.mts",
				"import": "./dist/index.mjs"
			}
		}
	},
	"dependencies": {
		"@types/hast": "^3.0.4",
		"unist-util-visit": "^5.0.0"
	},
	"peerDependencies": {
		"rehype-stringify": "^10.0.0",
		"remark-gfm": "^4.0.0",
		"remark-parse": "^11.0.0",
		"remark-rehype": "^11.0.0",
		"unified": "^11.0.0"
	},
	"devDependencies": {
		"rehype-stringify": "^10.0.1",
		"remark-gfm": "^4.0.1",
		"remark-parse": "^11.0.0",
		"remark-rehype": "^11.1.2",
		"unified": "^11.0.5"
	}
}
