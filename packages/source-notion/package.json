{
	"name": "@notion-headless-cms/source-notion",
	"version": "0.1.1",
	"description": "Notion DataSourceAdapter for notion-headless-cms — fetches pages from Notion databases",
	"keywords": [
		"notion",
		"notion-api",
		"headless-cms",
		"cms",
		"datasource",
		"adapter",
		"typescript"
	],
	"license": "MIT",
	"homepage": "https://github.com/kjfsm/notion-headless-cms#readme",
	"bugs": {
		"url": "https://github.com/kjfsm/notion-headless-cms/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/kjfsm/notion-headless-cms.git",
		"directory": "packages/source-notion"
	},
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"build": "tsup src/index.ts --format esm --dts --out-dir dist",
		"typecheck": "tsc --noEmit",
		"test": "vitest run"
	},
	"publishConfig": {
		"registry": "https://registry.npmjs.org",
		"access": "public",
		"exports": {
			".": {
				"import": "./dist/index.js",
				"types": "./dist/index.d.ts"
			}
		}
	},
	"dependencies": {
		"@notion-headless-cms/core": "workspace:*",
		"@notion-headless-cms/fetcher": "workspace:*",
		"@notion-headless-cms/transformer": "workspace:*",
		"@notionhq/client": "^5.18.0",
		"zod": "^4.1.12"
	}
}
