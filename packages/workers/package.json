{
  "name": "@kjfsm/notion-workers",
  "version": "0.0.1",
  "description": "Cloudflare Workers integration for Notion headless CMS",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "lint": "biome lint src",
    "format": "biome format src --write",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "dependencies": {
    "@kjfsm/notion-core": "workspace:*",
    "@kjfsm/notion-cache": "workspace:*"
  },
  "devDependencies": {}
}
