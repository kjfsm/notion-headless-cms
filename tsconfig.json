{
	"compilerOptions": {
		"strict": true,
		"lib": ["ES2022"],
		"types": ["@cloudflare/workers-types"],
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"verbatimModuleSyntax": true,
		"skipLibCheck": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true
	}
}
