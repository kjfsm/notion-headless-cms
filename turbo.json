{
	"$schema": "./node_modules/turbo/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**"]
		},
		"typecheck": {
			"dependsOn": ["^build"],
			"outputs": []
		},
		"test": {
			"dependsOn": ["^build"],
			"outputs": []
		},
		"generate": {
			"dependsOn": ["@notion-headless-cms/cli#build"],
			"inputs": ["nhc.config.ts"],
			"outputs": ["src/generated/**", "app/generated/**"]
		}
	}
}
