{
	"$schema": "./node_modules/turbo/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**"]
		},
		"typecheck": {
			"dependsOn": ["^build"],
			"outputs": []
		},
		"test": {
			"dependsOn": ["^build"],
			"outputs": []
		},
		"generate": {
			"dependsOn": ["@notion-headless-cms/cli#build"],
			"inputs": ["nhc.config.ts", ".env", ".dev.vars"],
			"outputs": ["src/generated/**", "app/generated/**"],
			"passThroughEnv": ["NOTION_TOKEN", "NOTION_DATA_SOURCE_ID", "DB_NAME"]
		}
	}
}
