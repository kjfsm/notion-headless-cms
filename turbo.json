{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**"],
			"passThroughEnv": [
				"NOTION_TOKEN",
				"NOTION_DATA_SOURCE_ID",
				"DB_NAME",
				"NOTION_DB_NAME",
				"NODE_EXTRA_CA_CERTS",
				"SSL_CERT_FILE"
			]
		},
		"typecheck": {
			"dependsOn": ["^build"],
			"outputs": []
		}
	}
}
